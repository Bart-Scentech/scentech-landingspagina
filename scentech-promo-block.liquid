{%- liquid
  assign section_bg_color = section.settings.section_bg_color
  assign card_bg_color = section.settings.card_bg_color
  assign text_color = section.settings.text_color
  assign subtext_color = section.settings.subtext_color
  assign accent_color = section.settings.accent_color
  assign button_bg_color = section.settings.button_bg_color
  assign button_text_color = section.settings.button_text_color
  
  assign heading_font = section.settings.heading_font
  assign body_font = section.settings.body_font
-%}

<style>
  {{ heading_font | font_face: font_display: 'swap' }}
  {{ body_font | font_face: font_display: 'swap' }}

  .scentech-promo-{{ section.id }} {
    --section-bg: {{ section_bg_color }};
    --card-bg: {{ card_bg_color }};
    --text-color: {{ text_color }};
    --subtext-color: {{ subtext_color }};
    --accent-color: {{ accent_color }};
    --btn-bg: {{ button_bg_color }};
    --btn-text: {{ button_text_color }};
    
    --font-heading: {{ heading_font.family }}, {{ heading_font.fallback_families }};
    --font-body: {{ body_font.family }}, {{ body_font.fallback_families }};
    
    background: var(--section-bg);
    padding: clamp(60px, 8vw, 100px) 24px;
    display: flex;
    justify-content: center;
    color: var(--text-color);
    font-family: var(--font-body);
  }

  .scentech-promo-{{ section.id }} *, .scentech-promo-{{ section.id }} *::before, .scentech-promo-{{ section.id }} *::after {
    box-sizing: border-box;
  }

  .scentech-promo-{{ section.id }}__container {
    max-width: 1000px;
    width: 100%;
    background: var(--card-bg);
    border-radius: {{ section.settings.corner_radius }}px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    overflow: hidden;
    box-shadow: 0 30px 60px rgba(0,0,0,0.3);
  }

  /* REVERSE OPTION */
  {% if section.settings.image_position == 'right' %}
    .scentech-promo-{{ section.id }}__content { order: 1; }
    .scentech-promo-{{ section.id }}__image { order: 2; }
  {% else %}
    .scentech-promo-{{ section.id }}__image { order: 1; }
    .scentech-promo-{{ section.id }}__content { order: 2; }
  {% endif %}

  .scentech-promo-{{ section.id }}__image {
    position: relative;
  }

  .scentech-promo-{{ section.id }}__image img, .scentech-promo-{{ section.id }}__image svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    min-height: 400px;
  }
  
  .scentech-promo-{{ section.id }}__image svg {
    background: #333;
  }

  .scentech-promo-{{ section.id }}__content {
    padding: clamp(40px, 6vw, 60px);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .scentech-promo-{{ section.id }}__eyebrow {
    color: var(--accent-color);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .scentech-promo-{{ section.id }}__title {
    font-family: var(--font-heading);
    font-size: clamp(28px, 3vw, 36px);
    font-weight: 700;
    margin-bottom: 12px;
    line-height: 1.2;
    color: var(--text-color);
  }

  .scentech-promo-{{ section.id }}__offer {
    font-size: 20px;
    font-weight: 400;
    margin-bottom: 32px;
    color: var(--subtext-color);
  }

  .scentech-promo-{{ section.id }}__offer span {
    color: var(--accent-color);
    font-weight: 700;
    font-size: 22px;
  }

  .scentech-promo-{{ section.id }}__usps {
    list-style: none;
    margin-bottom: 36px;
    padding: 0;
  }

  .scentech-promo-{{ section.id }}__usps li {
    margin-bottom: 12px;
    font-size: 15px;
    display: flex;
    align-items: center;
    gap: 12px;
    color: var(--subtext-color);
  }

  .scentech-promo-{{ section.id }}__usps li::before {
    content: '✓';
    color: var(--accent-color);
    font-weight: bold;
  }

  .scentech-promo-{{ section.id }}__btn {
    background: var(--btn-bg);
    color: var(--btn-text);
    border: 1px solid var(--btn-bg);
    font-size: 15px;
    font-weight: 600;
    padding: 15px 28px;
    text-decoration: none;
    width: fit-content;
    border-radius: {{ section.settings.btn_radius }}px;
    transition: opacity 0.2s ease;
    text-align: center;
  }

  .scentech-promo-{{ section.id }}__btn:hover {
    opacity: 0.9;
  }

  @media (max-width: 860px) {
    .scentech-promo-{{ section.id }} {
      padding: 60px 24px;
    }
    .scentech-promo-{{ section.id }}__container {
      grid-template-columns: 1fr;
    }
    .scentech-promo-{{ section.id }}__image {
      order: -1 !important; /* Image always on top for mobile */
    }
    .scentech-promo-{{ section.id }}__image img, .scentech-promo-{{ section.id }}__image svg {
      min-height: 300px;
    }
    .scentech-promo-{{ section.id }}__btn {
      width: 100%;
    }
  }
</style>

<div class="scentech-promo-{{ section.id }}">
  <div class="scentech-promo-{{ section.id }}__container">
    
    <div class="scentech-promo-{{ section.id }}__image">
      {% if section.settings.image != blank %}
        {{ section.settings.image | image_url: width: 800 | image_tag: loading: 'lazy' }}
      {% else %}
        {{ 'product-2' | placeholder_svg_tag: 'placeholder-svg' }}
      {% endif %}
    </div>
    
    <div class="scentech-promo-{{ section.id }}__content">
      {% if section.settings.eyebrow != blank %}
        <div class="scentech-promo-{{ section.id }}__eyebrow">{{ section.settings.eyebrow }}</div>
      {% endif %}
      
      <h2 class="scentech-promo-{{ section.id }}__title">{{ section.settings.title }}</h2>
      
      <div class="scentech-promo-{{ section.id }}__offer">
        {{ section.settings.offer_html }}
      </div>
      
      <ul class="scentech-promo-{{ section.id }}__usps">
        {% if section.settings.usp_1 != blank %}<li>{{ section.settings.usp_1 }}</li>{% endif %}
        {% if section.settings.usp_2 != blank %}<li>{{ section.settings.usp_2 }}</li>{% endif %}
        {% if section.settings.usp_3 != blank %}<li>{{ section.settings.usp_3 }}</li>{% endif %}
        {% if section.settings.usp_4 != blank %}<li>{{ section.settings.usp_4 }}</li>{% endif %}
      </ul>
      
      {% if section.settings.btn_text != blank %}
        <a href="{{ section.settings.btn_link }}" class="scentech-promo-{{ section.id }}__btn">{{ section.settings.btn_text }}</a>
      {% endif %}
    </div>
    
  </div>
</div>

{% schema %}
{
  "name": "Promo Block (Scentech)",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image Position (Desktop)",
      "options": [
        { "value": "left", "label": "Image Left" },
        { "value": "right", "label": "Image Right" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Text Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "Exclusief Aanbod"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Smart Aroma Diffuser 2"
    },
    {
      "type": "html",
      "id": "offer_html",
      "label": "Offer Text (HTML allowed)",
      "default": "Nu <span>Gratis</span> vanaf 7 geuren"
    },
    {
      "type": "header",
      "content": "USPs (Checkmarks)"
    },
    {
      "type": "text",
      "id": "usp_1",
      "label": "USP 1",
      "default": "30 dagen lang zonder omkijken"
    },
    {
      "type": "text",
      "id": "usp_2",
      "label": "USP 2",
      "default": "Bereik tot maar liefst 65m²"
    },
    {
      "type": "text",
      "id": "usp_3",
      "label": "USP 3",
      "default": "Uniek antilek systeem (veilig voor meubels)"
    },
    {
      "type": "text",
      "id": "usp_4",
      "label": "USP 4"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button Text",
      "default": "Claim jouw gratis diffuser"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Product Image"
    },
    {
      "type": "header",
      "content": "Styling & Colors"
    },
    {
      "type": "range",
      "id": "corner_radius",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "label": "Card Corner Radius",
      "default": 12
    },
    {
      "type": "range",
      "id": "btn_radius",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "label": "Button Corner Radius",
      "default": 4
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Section Background",
      "default": "#1A1A1A"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card Background",
      "default": "#252525"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Title Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "subtext_color",
      "label": "Text / USP Color",
      "default": "#E8E2DB"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color (Highlight & Eyebrow)",
      "default": "#C9A96E"
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Button Background",
      "default": "#C9A96E"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button Text",
      "default": "#1A1A1A"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Heading Font",
      "default": "playfair_display_n7"
    },
    {
      "type": "font_picker",
      "id": "body_font",
      "label": "Body Font",
      "default": "inter_n4"
    }
  ],
  "presets": [
    {
      "name": "Promo Block (Scentech)"
    }
  ]
}
{% endschema %}
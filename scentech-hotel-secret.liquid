{%- liquid
  assign bg_color = section.settings.bg_color
  assign text_color = section.settings.text_color
  assign subtext_color = section.settings.subtext_color
  assign highlight_bg = section.settings.highlight_bg
  assign accent_color = section.settings.accent_color
  
  assign heading_font = section.settings.heading_font
  assign body_font = section.settings.body_font
-%}

<style>
  {{ heading_font | font_face: font_display: 'swap' }}
  {{ body_font | font_face: font_display: 'swap' }}

  .scentech-hotel-secret-{{ section.id }} {
    --bg-color: {{ bg_color }};
    --text-color: {{ text_color }};
    --subtext-color: {{ subtext_color }};
    --highlight-bg: {{ highlight_bg }};
    --accent-color: {{ accent_color }};
    
    --font-heading: {{ heading_font.family }}, {{ heading_font.fallback_families }};
    --font-body: {{ body_font.family }}, {{ body_font.fallback_families }};
    
    background: var(--bg-color);
    padding: clamp(60px, 8vw, 100px) 24px;
    display: flex;
    justify-content: center;
    font-family: var(--font-body);
  }

  .scentech-hotel-secret-{{ section.id }} *, .scentech-hotel-secret-{{ section.id }} *::before, .scentech-hotel-secret-{{ section.id }} *::after {
    box-sizing: border-box;
  }

  .scentech-hotel-secret-{{ section.id }}__container {
    max-width: 680px;
    width: 100%;
  }

  .scentech-hotel-secret-{{ section.id }}__title {
    font-family: var(--font-heading);
    font-size: clamp(24px, 3vw, 36px);
    font-weight: 700;
    color: var(--text-color);
    margin-bottom: 32px;
    text-align: center;
    line-height: 1.2;
  }

  .scentech-hotel-secret-{{ section.id }}__content {
    font-size: 16px;
    color: var(--subtext-color);
    line-height: 1.8;
  }

  .scentech-hotel-secret-{{ section.id }}__content p {
    margin-bottom: 24px;
  }

  .scentech-hotel-secret-{{ section.id }}__highlight {
    background: var(--highlight-bg);
    border-left: 4px solid var(--accent-color);
    padding: 32px;
    margin: 40px 0;
    border-radius: 0 8px 8px 0;
  }

  .scentech-hotel-secret-{{ section.id }}__highlight h3 {
    font-family: var(--font-heading);
    font-size: 20px;
    color: var(--text-color);
    margin-bottom: 12px;
  }

  .scentech-hotel-secret-{{ section.id }}__highlight p {
    margin-bottom: 0;
    color: var(--text-color);
  }

  @media (max-width: 860px) {
    .scentech-hotel-secret-{{ section.id }} {
      padding: 60px 24px;
    }
    .scentech-hotel-secret-{{ section.id }}__highlight {
      padding: 24px;
      margin: 32px 0;
    }
  }
</style>

<div class="scentech-hotel-secret-{{ section.id }}" id="{{ section.settings.section_id }}">
  <div class="scentech-hotel-secret-{{ section.id }}__container">
    <h2 class="scentech-hotel-secret-{{ section.id }}__title">{{ section.settings.title }}</h2>
    
    <div class="scentech-hotel-secret-{{ section.id }}__content">
      {% if section.settings.text_part_1 != blank %}
        {{ section.settings.text_part_1 }}
      {% endif %}
      
      {% if section.settings.highlight_title != blank or section.settings.highlight_text != blank %}
      <div class="scentech-hotel-secret-{{ section.id }}__highlight">
        {% if section.settings.highlight_title != blank %}
          <h3>{{ section.settings.highlight_title }}</h3>
        {% endif %}
        {% if section.settings.highlight_text != blank %}
          {{ section.settings.highlight_text }}
        {% endif %}
      </div>
      {% endif %}
      
      {% if section.settings.text_part_2 != blank %}
        {{ section.settings.text_part_2 }}
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Hotel Secret (Scentech)",
  "settings": [
    {
      "type": "text",
      "id": "section_id",
      "label": "Section Anchor ID",
      "default": "redenen",
      "info": "Id waar de 'Ontdek waarom' knop naartoe scrollt"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Waarom ruiken luxe hotels altijd perfect?"
    },
    {
      "type": "richtext",
      "id": "text_part_1",
      "label": "Text (Before Highlight)",
      "default": "<p>Dat komt niet door geurstokjes.</p><p>Achter de schermen gebruiken ze professionele geurapparaten. Maar die geurapparaten zijn anders dan wat jij thuis waarschijnlijk kent. Thuis verdun je je olie vaak met water, wat vervolgens als een vochtige mist wordt verspreid.</p>"
    },
    {
      "type": "header",
      "content": "Highlight Box"
    },
    {
      "type": "text",
      "id": "highlight_title",
      "label": "Highlight Title",
      "default": "Het geheim: Cold Air Diffusion"
    },
    {
      "type": "richtext",
      "id": "highlight_text",
      "label": "Highlight Text",
      "default": "<p>In hotels maken ze gebruik van <strong>Cold Air Diffusion</strong>. Een technologie waarbij de pure olie onder hoge druk wordt verneveld tot onzichtbare microdeeltjes die zich verspreiden via de luchtstroom. Zonder water of hitte, en zonder neer te slaan op je meubels.</p>"
    },
    {
      "type": "header",
      "content": "Text After"
    },
    {
      "type": "richtext",
      "id": "text_part_2",
      "label": "Text (After Highlight)",
      "default": "<p>En precies deze hotel-technologie hebben wij nu, in een compact en stijlvol design, beschikbaar gemaakt voor consumenten.</p>"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "highlight_bg",
      "label": "Highlight Box Background",
      "default": "#FAF7F4"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color (Border)",
      "default": "#C9A96E"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Heading & Bold Text Color",
      "default": "#1A1A1A"
    },
    {
      "type": "color",
      "id": "subtext_color",
      "label": "Body Text Color",
      "default": "#4A4A4A"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Heading Font",
      "default": "playfair_display_n7"
    },
    {
      "type": "font_picker",
      "id": "body_font",
      "label": "Body Font",
      "default": "inter_n4"
    }
  ],
  "presets": [
    {
      "name": "Hotel Secret (Scentech)"
    }
  ]
}
{% endschema %}
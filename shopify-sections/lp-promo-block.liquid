{% comment %}
  LP Promo Block
  Scentech — Horizontale productkaart met label, afbeelding, USPs en CTA
{% endcomment %}

<style>
  #lp-promo-block-{{ section.id }} {
    --color-bg:       {{ section.settings.color_bg }};
    --color-text:     {{ section.settings.color_text }};
    --color-btn-bg:   {{ section.settings.color_btn_bg }};
    --color-btn-text: {{ section.settings.color_btn_text }};
    --color-label-bg: {{ section.settings.color_label_bg }};
    --font-heading:   '{{ section.settings.font_heading }}', sans-serif;
    --font-body:      '{{ section.settings.font_body }}', sans-serif;
    --font-btn:       '{{ section.settings.font_btn }}', sans-serif;
  }

  #lp-promo-block-{{ section.id }} .promo-block {
    background: var(--color-bg);
    padding: clamp(40px, 6vw, 80px) 24px;
    display: flex;
    justify-content: center;
  }

  #lp-promo-block-{{ section.id }} .promo-block__container {
    position: relative;
    margin-top: 24px;
    max-width: 900px;
    width: 100%;
    background: var(--color-bg);
    border: 1px solid rgba(35, 31, 32, 0.12);
    border-radius: 8px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    padding: 16px;
    gap: 32px;
    align-items: center;
    box-shadow: 0 5px 15px rgba(35, 31, 32, 0.06);
  }

  #lp-promo-block-{{ section.id }} .promo-block__image {
    border-radius: 6px;
    overflow: hidden;
    height: 100%;
  }

  #lp-promo-block-{{ section.id }} .promo-block__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    aspect-ratio: 3/4;
  }

  #lp-promo-block-{{ section.id }} .lp-placeholder {
    width: 100%;
    aspect-ratio: 3/4;
    background: linear-gradient(160deg, #F5EFE8 0%, #EAE0D4 40%, #DDD0BC 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    color: #8A8A8A;
    letter-spacing: 0.08em;
    border-radius: 6px;
  }

  #lp-promo-block-{{ section.id }} .promo-block__content {
    padding: 16px 24px 16px 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  #lp-promo-block-{{ section.id }} .promo-block__title {
    font-family: var(--font-heading);
    font-size: clamp(20px, 2.5vw, 24px);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin-bottom: 12px;
    line-height: 1.3;
  }

  #lp-promo-block-{{ section.id }} .promo-block__desc {
    font-size: 15px;
    color: var(--color-text);
    opacity: 0.7;
    line-height: 1.6;
    margin-bottom: 8px;
    font-family: var(--font-body);
  }

  #lp-promo-block-{{ section.id }} .promo-block__offer {
    font-size: 16px;
    color: var(--color-text);
    font-weight: 700;
    margin-bottom: 16px;
    font-family: var(--font-body);
  }

  #lp-promo-block-{{ section.id }} .promo-block__usps {
    list-style: none;
    margin-bottom: 24px;
    padding: 0;
  }

  #lp-promo-block-{{ section.id }} .promo-block__usps li {
    margin-bottom: 8px;
    font-size: 14px;
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--color-text);
    opacity: 0.7;
    font-family: var(--font-body);
  }

  #lp-promo-block-{{ section.id }} .promo-block__usps li::before {
    content: '✓';
    color: var(--color-text);
    opacity: 1;
    font-weight: bold;
    font-size: 12px;
  }

  #lp-promo-block-{{ section.id }} .promo-block__btn {
    background: var(--color-btn-bg);
    color: var(--color-btn-text);
    border: none;
    font-family: var(--font-btn);
    font-size: 16px;
    font-weight: 700;
    padding: 17px 40px;
    width: fit-content;
    border-radius: 4px;
    text-align: center;
    text-decoration: none;
    display: inline-block;
    transition: opacity 0.2s;
  }

  #lp-promo-block-{{ section.id }} .promo-block__btn:hover {
    opacity: 0.85;
  }

  #lp-promo-block-{{ section.id }} .promo-block__label {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translate(-50%, -50%);
    background: var(--color-label-bg);
    color: var(--color-btn-text);
    padding: 6px 16px;
    border-radius: 4px;
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  @media (max-width: 860px) {
    #lp-promo-block-{{ section.id }} .promo-block {
      padding: 32px 16px;
    }
    #lp-promo-block-{{ section.id }} .promo-block__container {
      grid-template-columns: 1fr;
      padding: 16px;
      gap: 24px;
    }
    #lp-promo-block-{{ section.id }} .promo-block__image {
      order: -1;
    }
    #lp-promo-block-{{ section.id }} .promo-block__image img {
      aspect-ratio: auto;
      height: auto;
      width: 100%;
    }
    #lp-promo-block-{{ section.id }} .promo-block__content {
      padding: 0 4px 8px 4px;
    }
    #lp-promo-block-{{ section.id }} .promo-block__title {
      font-size: 20px;
      margin-bottom: 8px;
    }
    #lp-promo-block-{{ section.id }} .promo-block__btn {
      width: 100%;
      text-align: center;
      padding: 14px 16px;
      font-size: 15px;
    }
  }
</style>

<section id="lp-promo-block-{{ section.id }}" class="lp-promo-block-section">
  <div class="promo-block">
    <div class="promo-block__container">

      {% if section.settings.show_label %}
        <div class="promo-block__label">{{ section.settings.label_text }}</div>
      {% endif %}

      <!-- Afbeelding -->
      <div class="promo-block__image">
        {% if section.settings.product_image != blank %}
          {{ section.settings.product_image | image_url: width: 1200 | image_tag: alt: section.settings.title }}
        {% else %}
          <div class="lp-placeholder">Voeg productfoto toe</div>
        {% endif %}
      </div>

      <!-- Inhoud -->
      <div class="promo-block__content">
        <h2 class="promo-block__title">{{ section.settings.title }}</h2>

        {% if section.settings.show_description %}
          <p class="promo-block__desc">{{ section.settings.description }}</p>
        {% endif %}

        <p class="promo-block__offer"><strong>{{ section.settings.offer_text }}</strong></p>

        <ul class="promo-block__usps">
          {% if section.settings.show_usp_1 %}
            <li>{{ section.settings.usp_item_1 }}</li>
          {% endif %}
          {% if section.settings.show_usp_2 %}
            <li>{{ section.settings.usp_item_2 }}</li>
          {% endif %}
          {% if section.settings.show_usp_3 %}
            <li>{{ section.settings.usp_item_3 }}</li>
          {% endif %}
          {% if section.settings.show_usp_4 %}
            <li>{{ section.settings.usp_item_4 }}</li>
          {% endif %}
        </ul>

        <a href="{{ section.settings.cta_url }}" class="promo-block__btn">{{ section.settings.cta_text }}</a>
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "LP Promo Blok",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Label"
    },
    {
      "type": "checkbox",
      "id": "show_label",
      "label": "Toon label",
      "default": true
    },
    {
      "type": "text",
      "id": "label_text",
      "label": "Label tekst",
      "default": "SPRING SALE"
    },
    {
      "type": "header",
      "content": "Product"
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Product afbeelding"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Producttitel",
      "default": "Smart Aroma Diffuser 2"
    },
    {
      "type": "header",
      "content": "Omschrijving"
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Toon omschrijving",
      "default": true
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Omschrijving",
      "default": "Onze diffusers leveren een hotelwaardige geurbeleving dankzij geavanceerde Cold-Air Diffusion Technology. Luxe geur met één druk op de knop."
    },
    {
      "type": "text",
      "id": "offer_text",
      "label": "Aanbieding tekst (vetgedrukt)",
      "default": "Nu GRATIS vanaf 7 geuren!"
    },
    {
      "type": "header",
      "content": "USP's"
    },
    {
      "type": "checkbox",
      "id": "show_usp_1",
      "label": "Toon USP 1",
      "default": true
    },
    {
      "type": "text",
      "id": "usp_item_1",
      "label": "USP 1",
      "default": "30 dagen lang zonder omkijken"
    },
    {
      "type": "checkbox",
      "id": "show_usp_2",
      "label": "Toon USP 2",
      "default": true
    },
    {
      "type": "text",
      "id": "usp_item_2",
      "label": "USP 2",
      "default": "Bereik tot maar liefst 65m²"
    },
    {
      "type": "checkbox",
      "id": "show_usp_3",
      "label": "Toon USP 3",
      "default": true
    },
    {
      "type": "text",
      "id": "usp_item_3",
      "label": "USP 3",
      "default": "Uniek antilek systeem"
    },
    {
      "type": "checkbox",
      "id": "show_usp_4",
      "label": "Toon USP 4",
      "default": false
    },
    {
      "type": "text",
      "id": "usp_item_4",
      "label": "USP 4",
      "default": "Vul hier USP 4 in"
    },
    {
      "type": "header",
      "content": "CTA knop"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Knoptekst",
      "default": "Claim jouw gratis diffuser"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Knop URL"
    },
    {
      "type": "header",
      "content": "Kleuren"
    },
    {
      "type": "color",
      "id": "color_bg",
      "label": "Achtergrondkleur",
      "default": "#F1F1F1"
    },
    {
      "type": "color",
      "id": "color_text",
      "label": "Tekstkleur",
      "default": "#231F20"
    },
    {
      "type": "color",
      "id": "color_btn_bg",
      "label": "Knop achtergrondkleur",
      "default": "#160000"
    },
    {
      "type": "color",
      "id": "color_btn_text",
      "label": "Knop tekstkleur",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "color_label_bg",
      "label": "Label achtergrondkleur",
      "default": "#160000"
    },
    {
      "type": "header",
      "content": "Lettertypes"
    },
    {
      "type": "select",
      "id": "font_heading",
      "label": "Lettertype koptekst",
      "options": [
        { "value": "Bai Jamjuree", "label": "Bai Jamjuree" },
        { "value": "Playfair Display", "label": "Playfair Display" },
        { "value": "Inter", "label": "Inter" }
      ],
      "default": "Bai Jamjuree"
    },
    {
      "type": "select",
      "id": "font_body",
      "label": "Lettertype bodytekst",
      "options": [
        { "value": "Bai Jamjuree", "label": "Bai Jamjuree" },
        { "value": "Playfair Display", "label": "Playfair Display" },
        { "value": "Inter", "label": "Inter" }
      ],
      "default": "Bai Jamjuree"
    },
    {
      "type": "select",
      "id": "font_btn",
      "label": "Lettertype knop",
      "options": [
        { "value": "Bai Jamjuree", "label": "Bai Jamjuree" },
        { "value": "Playfair Display", "label": "Playfair Display" },
        { "value": "Inter", "label": "Inter" }
      ],
      "default": "Bai Jamjuree"
    }
  ],
  "presets": [
    {
      "name": "LP Promo Blok"
    }
  ]
}
{% endschema %}

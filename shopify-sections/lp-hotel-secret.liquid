{% comment %}
  LP Hotel Secret Section
  Scentech — "Waarom ruiken luxe hotels altijd perfect?" sectie
{% endcomment %}

<style>
  #lp-hotel-secret-{{ section.id }} {
    --color-bg:             {{ section.settings.color_bg }};
    --color-text:           {{ section.settings.color_text }};
    --color-highlight-bg:   {{ section.settings.color_highlight_bg }};
    --color-highlight-border: {{ section.settings.color_highlight_border }};
    --font-heading:         '{{ section.settings.font_heading }}', sans-serif;
    --font-body:            '{{ section.settings.font_body }}', sans-serif;
  }

  #lp-hotel-secret-{{ section.id }} .hotel-secret {
    background: var(--color-bg);
    padding: clamp(60px, 8vw, 100px) 24px;
    display: flex;
    justify-content: center;
  }

  #lp-hotel-secret-{{ section.id }} .hotel-secret__container {
    max-width: 1080px;
    width: 100%;
    display: grid;
    gap: clamp(40px, 6vw, 80px);
    align-items: center;
  }

  #lp-hotel-secret-{{ section.id }} .hotel-secret__container.image-left {
    grid-template-columns: 1fr 1fr;
  }

  #lp-hotel-secret-{{ section.id }} .hotel-secret__container.image-right {
    grid-template-columns: 1fr 1fr;
  }

  #lp-hotel-secret-{{ section.id }} .hotel-secret__container.image-right .hotel-secret__image {
    order: 2;
  }

  #lp-hotel-secret-{{ section.id }} .hotel-secret__container.image-right .hotel-secret__text-col {
    order: 1;
  }

  #lp-hotel-secret-{{ section.id }} .hotel-secret__image {
    border-radius: 4px;
    overflow: hidden;
    box-shadow: 0 18px 50px rgba(35, 31, 32, 0.1);
  }

  #lp-hotel-secret-{{ section.id }} .hotel-secret__image img {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 4/5;
    object-fit: cover;
  }

  #lp-hotel-secret-{{ section.id }} .lp-placeholder {
    width: 100%;
    aspect-ratio: 4/5;
    background: linear-gradient(160deg, #F5EFE8 0%, #EAE0D4 40%, #DDD0BC 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    color: #8A8A8A;
    letter-spacing: 0.08em;
  }

  #lp-hotel-secret-{{ section.id }} .hotel-secret__title {
    font-family: var(--font-heading);
    font-size: clamp(24px, 3vw, 36px);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin-bottom: 32px;
    text-align: left;
  }

  #lp-hotel-secret-{{ section.id }} .hotel-secret__content {
    font-size: 16px;
    color: var(--color-text);
    opacity: 0.75;
    line-height: 1.8;
    font-family: var(--font-body);
  }

  #lp-hotel-secret-{{ section.id }} .hotel-secret__content p {
    margin-bottom: 24px;
  }

  #lp-hotel-secret-{{ section.id }} .hotel-secret__highlight {
    background: var(--color-highlight-bg);
    border-left: 4px solid var(--color-highlight-border);
    padding: 32px;
    margin: 40px 0;
    border-radius: 0 8px 8px 0;
  }

  #lp-hotel-secret-{{ section.id }} .hotel-secret__highlight h3 {
    font-family: var(--font-heading);
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-text);
    opacity: 1;
    margin-bottom: 12px;
  }

  #lp-hotel-secret-{{ section.id }} .hotel-secret__highlight p {
    margin-bottom: 0;
    color: var(--color-text);
    opacity: 1;
  }

  @media (max-width: 860px) {
    #lp-hotel-secret-{{ section.id }} .hotel-secret {
      padding: 60px 0;
    }
    #lp-hotel-secret-{{ section.id }} .hotel-secret__container,
    #lp-hotel-secret-{{ section.id }} .hotel-secret__container.image-left,
    #lp-hotel-secret-{{ section.id }} .hotel-secret__container.image-right {
      grid-template-columns: 1fr;
      gap: 0;
    }
    #lp-hotel-secret-{{ section.id }} .hotel-secret__text-col {
      padding: 40px 24px 0;
      order: 2 !important;
    }
    #lp-hotel-secret-{{ section.id }} .hotel-secret__image {
      border-radius: 0;
      box-shadow: none;
      order: 1 !important;
      width: 100%;
    }
    #lp-hotel-secret-{{ section.id }} .hotel-secret__image img {
      aspect-ratio: auto;
      height: auto;
      width: 100%;
    }
    #lp-hotel-secret-{{ section.id }} .hotel-secret__highlight {
      padding: 24px;
      margin: 32px 0;
    }
  }
</style>

<section id="lp-hotel-secret-{{ section.id }}" class="lp-hotel-secret-section">
  <div class="hotel-secret">
    <div class="hotel-secret__container {% if section.settings.image_position == 'left' %}image-left{% else %}image-right{% endif %}">

      <div class="hotel-secret__text-col">
        <h2 class="hotel-secret__title">{{ section.settings.section_title }}</h2>
        <div class="hotel-secret__content">
          <p>{{ section.settings.body_paragraph_1 }}</p>
          <p>{{ section.settings.body_paragraph_2 }}</p>

          {% if section.settings.show_highlight %}
            <div class="hotel-secret__highlight">
              <h3>{{ section.settings.highlight_title }}</h3>
              <p>{{ section.settings.highlight_body }}</p>
            </div>
          {% endif %}

          <p>{{ section.settings.final_paragraph }}</p>
        </div>
      </div>

      <div class="hotel-secret__image">
        {% if section.settings.image != blank %}
          {{ section.settings.image | image_url: width: 1200 | image_tag: alt: section.settings.section_title }}
        {% else %}
          <div class="lp-placeholder">Voeg afbeelding toe</div>
        {% endif %}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "LP Hotel Secret",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Teksten"
    },
    {
      "type": "text",
      "id": "section_title",
      "label": "Sectietitel",
      "default": "Waarom ruiken luxe hotels altijd perfect?"
    },
    {
      "type": "textarea",
      "id": "body_paragraph_1",
      "label": "Eerste alinea",
      "default": "Dat komt niet door geurstokjes."
    },
    {
      "type": "textarea",
      "id": "body_paragraph_2",
      "label": "Tweede alinea",
      "default": "Achter de schermen gebruiken ze professionele geurapparaten. Maar die geurapparaten zijn anders dan wat jij thuis waarschijnlijk kent. Thuis verdun je je olie vaak met water, wat vervolgens als een vochtige mist wordt verspreid."
    },
    {
      "type": "header",
      "content": "Highlight box"
    },
    {
      "type": "checkbox",
      "id": "show_highlight",
      "label": "Toon highlight box",
      "default": true
    },
    {
      "type": "text",
      "id": "highlight_title",
      "label": "Highlight titel",
      "default": "Het geheim: Cold Air Diffusion"
    },
    {
      "type": "textarea",
      "id": "highlight_body",
      "label": "Highlight tekst",
      "default": "In hotels maken ze gebruik van Cold Air Diffusion. Een technologie waarbij de pure olie onder hoge druk wordt verneveld tot onzichtbare microdeeltjes die zich verspreiden via de luchtstroom. Zonder water of hitte, en zonder neer te slaan op je meubels."
    },
    {
      "type": "header",
      "content": "Laatste alinea"
    },
    {
      "type": "textarea",
      "id": "final_paragraph",
      "label": "Afsluitende alinea",
      "default": "En precies deze hotel-technologie hebben wij nu, in een compact en stijlvol design, beschikbaar gemaakt voor consumenten."
    },
    {
      "type": "header",
      "content": "Afbeelding"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Sectie afbeelding"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Afbeelding positie",
      "options": [
        { "value": "left", "label": "Links" },
        { "value": "right", "label": "Rechts" }
      ],
      "default": "right"
    },
    {
      "type": "header",
      "content": "Kleuren"
    },
    {
      "type": "color",
      "id": "color_bg",
      "label": "Achtergrondkleur",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "color_text",
      "label": "Tekstkleur",
      "default": "#231F20"
    },
    {
      "type": "color",
      "id": "color_highlight_border",
      "label": "Highlight randkleur",
      "default": "#160000"
    },
    {
      "type": "color",
      "id": "color_highlight_bg",
      "label": "Highlight achtergrond",
      "default": "#F1F1F1"
    },
    {
      "type": "header",
      "content": "Lettertypes"
    },
    {
      "type": "select",
      "id": "font_heading",
      "label": "Lettertype koptekst",
      "options": [
        { "value": "Bai Jamjuree", "label": "Bai Jamjuree" },
        { "value": "Playfair Display", "label": "Playfair Display" },
        { "value": "Inter", "label": "Inter" }
      ],
      "default": "Bai Jamjuree"
    },
    {
      "type": "select",
      "id": "font_body",
      "label": "Lettertype bodytekst",
      "options": [
        { "value": "Bai Jamjuree", "label": "Bai Jamjuree" },
        { "value": "Playfair Display", "label": "Playfair Display" },
        { "value": "Inter", "label": "Inter" }
      ],
      "default": "Bai Jamjuree"
    }
  ],
  "presets": [
    {
      "name": "LP Hotel Secret"
    }
  ]
}
{% endschema %}

{% comment %}
  LP Hotel Secret Section
  Scentech — "Waarom ruiken luxe hotels altijd perfect?"
{% endcomment %}

<style>
  #lp-hotel-secret-{{ section.id }} {
    --color-bg:               {{ section.settings.color_bg }};
    --color-text:             {{ section.settings.color_text }};
    --color-highlight-bg:     {{ section.settings.color_highlight_bg }};
    --color-highlight-border: {{ section.settings.color_highlight_border }};
    --font-heading:           '{{ section.settings.font_heading }}', sans-serif;
    --font-body:              '{{ section.settings.font_body }}', sans-serif;
  }

  /* ── Outer wrapper ── */
  #lp-hotel-secret-{{ section.id }} .hs-outer {
    background: var(--color-bg);
    padding: clamp(60px, 8vw, 100px) 24px;
    display: flex;
    justify-content: center;
  }

  /* ── Grid container ── */
  #lp-hotel-secret-{{ section.id }} .hs-grid {
    max-width: 1080px;
    width: 100%;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(40px, 6vw, 80px);
    align-items: center;
  }

  /* Image left: image col first, text col second */
  #lp-hotel-secret-{{ section.id }} .hs-grid.image-left .hs-image  { order: 1; }
  #lp-hotel-secret-{{ section.id }} .hs-grid.image-left .hs-text   { order: 2; }

  /* Image right: text col first, image col second */
  #lp-hotel-secret-{{ section.id }} .hs-grid.image-right .hs-text  { order: 1; }
  #lp-hotel-secret-{{ section.id }} .hs-grid.image-right .hs-image { order: 2; }

  /* ── Image column ── */
  #lp-hotel-secret-{{ section.id }} .hs-image {
    border-radius: 4px;
    overflow: hidden;
    box-shadow: 0 18px 50px rgba(35, 31, 32, 0.10);
  }

  #lp-hotel-secret-{{ section.id }} .hs-image img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: {{ section.settings.image_fit }};
    object-position: {{ section.settings.image_focal_point }};
  }

  /* Optional fixed aspect-ratio (only applied when image_fit = cover) */
  {% if section.settings.image_fit == 'cover' %}
  #lp-hotel-secret-{{ section.id }} .hs-image img {
    aspect-ratio: 4 / 5;
    height: 100%;
  }
  {% endif %}

  /* ── Placeholder ── */
  #lp-hotel-secret-{{ section.id }} .hs-placeholder {
    width: 100%;
    aspect-ratio: 4 / 5;
    background: linear-gradient(160deg, #F5EFE8 0%, #EAE0D4 40%, #DDD0BC 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    color: #8A8A8A;
    letter-spacing: 0.08em;
  }

  /* ── Text column ── */
  #lp-hotel-secret-{{ section.id }} .hs-title {
    font-family: var(--font-heading);
    font-size: clamp(24px, 3vw, 36px);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin: 0 0 32px;
  }

  #lp-hotel-secret-{{ section.id }} .hs-body {
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.8;
    color: var(--color-text);
    opacity: 0.75;
  }

  #lp-hotel-secret-{{ section.id }} .hs-body p {
    margin: 0 0 24px;
  }

  #lp-hotel-secret-{{ section.id }} .hs-body p:last-child {
    margin-bottom: 0;
  }

  /* ── Highlight box ── */
  #lp-hotel-secret-{{ section.id }} .hs-highlight {
    background: var(--color-highlight-bg);
    border-left: 4px solid var(--color-highlight-border);
    border-radius: 0 8px 8px 0;
    padding: 32px;
    margin: 40px 0;
  }

  #lp-hotel-secret-{{ section.id }} .hs-highlight h3 {
    font-family: var(--font-heading);
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin: 0 0 12px;
  }

  #lp-hotel-secret-{{ section.id }} .hs-highlight p {
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.7;
    color: var(--color-text);
    margin: 0;
    opacity: 0.85;
  }

  /* ── Mobile ── */
  @media (max-width: 860px) {
    #lp-hotel-secret-{{ section.id }} .hs-outer {
      padding: 60px 0;
    }

    #lp-hotel-secret-{{ section.id }} .hs-grid {
      grid-template-columns: 1fr;
      gap: 0;
    }

    /* On mobile: image always on top, text below */
    #lp-hotel-secret-{{ section.id }} .hs-grid .hs-image { order: 1 !important; }
    #lp-hotel-secret-{{ section.id }} .hs-grid .hs-text  { order: 2 !important; padding: 40px 24px 0; }

    #lp-hotel-secret-{{ section.id }} .hs-image {
      border-radius: 0;
      box-shadow: none;
      width: 100%;
    }

    #lp-hotel-secret-{{ section.id }} .hs-image img {
      aspect-ratio: unset !important;
      height: auto !important;
      width: 100%;
    }

    #lp-hotel-secret-{{ section.id }} .hs-highlight {
      padding: 24px;
      margin: 32px 0;
    }
  }
</style>

<section id="lp-hotel-secret-{{ section.id }}">
  <div class="hs-outer">
    <div class="hs-grid {% if section.settings.image_position == 'left' %}image-left{% else %}image-right{% endif %}">

      <div class="hs-text">
        <h2 class="hs-title">{{ section.settings.section_title }}</h2>
        <div class="hs-body">
          <p>{{ section.settings.body_paragraph_1 }}</p>
          <p>{{ section.settings.body_paragraph_2 }}</p>

          {% if section.settings.show_highlight %}
            <div class="hs-highlight">
              <h3>{{ section.settings.highlight_title }}</h3>
              <p>{{ section.settings.highlight_body }}</p>
            </div>
          {% endif %}

          <p>{{ section.settings.final_paragraph }}</p>
        </div>
      </div>

      <div class="hs-image">
        {% if section.settings.image != blank %}
          {{ section.settings.image | image_url: width: 1400 | image_tag:
            alt: section.settings.section_title,
            loading: 'lazy'
          }}
        {% else %}
          <div class="hs-placeholder">Voeg afbeelding toe</div>
        {% endif %}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "LP Hotel Secret",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Teksten"
    },
    {
      "type": "text",
      "id": "section_title",
      "label": "Sectietitel",
      "default": "Waarom ruiken luxe hotels altijd perfect?"
    },
    {
      "type": "textarea",
      "id": "body_paragraph_1",
      "label": "Eerste alinea",
      "default": "Dat komt niet door geurstokjes."
    },
    {
      "type": "textarea",
      "id": "body_paragraph_2",
      "label": "Tweede alinea",
      "default": "Achter de schermen gebruiken ze professionele geurapparaten. Maar die geurapparaten zijn anders dan wat jij thuis waarschijnlijk kent. Thuis verdun je je olie vaak met water, wat vervolgens als een vochtige mist wordt verspreid."
    },
    {
      "type": "header",
      "content": "Highlight box"
    },
    {
      "type": "checkbox",
      "id": "show_highlight",
      "label": "Toon highlight box",
      "default": true
    },
    {
      "type": "text",
      "id": "highlight_title",
      "label": "Highlight titel",
      "default": "Het geheim: Cold Air Diffusion"
    },
    {
      "type": "textarea",
      "id": "highlight_body",
      "label": "Highlight tekst",
      "default": "In hotels maken ze gebruik van Cold Air Diffusion. Een technologie waarbij de pure olie onder hoge druk wordt verneveld tot onzichtbare microdeeltjes die zich verspreiden via de luchtstroom. Zonder water of hitte, en zonder neer te slaan op je meubels."
    },
    {
      "type": "header",
      "content": "Afsluitende alinea"
    },
    {
      "type": "textarea",
      "id": "final_paragraph",
      "label": "Afsluitende alinea",
      "default": "En precies deze hotel-technologie hebben wij nu, in een compact en stijlvol design, beschikbaar gemaakt voor consumenten."
    },
    {
      "type": "header",
      "content": "Afbeelding"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Sectie afbeelding"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Positie afbeelding",
      "options": [
        { "value": "left",  "label": "Links" },
        { "value": "right", "label": "Rechts" }
      ],
      "default": "right"
    },
    {
      "type": "select",
      "id": "image_fit",
      "label": "Weergave afbeelding",
      "info": "Bijsnijden: vult het vlak (4:5 verhouding). Volledig: toont de hele afbeelding op zijn eigen formaat.",
      "options": [
        { "value": "cover",   "label": "Bijsnijden (4:5 vlak)" },
        { "value": "contain", "label": "Volledig tonen" }
      ],
      "default": "cover"
    },
    {
      "type": "select",
      "id": "image_focal_point",
      "label": "Focuspunt (bij bijsnijden)",
      "info": "Welk deel van de afbeelding blijft zichtbaar als hij wordt bijgesneden.",
      "options": [
        { "value": "center center", "label": "Midden" },
        { "value": "top center",    "label": "Boven" },
        { "value": "bottom center", "label": "Onder" },
        { "value": "center left",   "label": "Links" },
        { "value": "center right",  "label": "Rechts" },
        { "value": "top left",      "label": "Boven links" },
        { "value": "top right",     "label": "Boven rechts" },
        { "value": "bottom left",   "label": "Onder links" },
        { "value": "bottom right",  "label": "Onder rechts" }
      ],
      "default": "center center"
    },
    {
      "type": "header",
      "content": "Kleuren"
    },
    {
      "type": "color",
      "id": "color_bg",
      "label": "Achtergrond",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "color_text",
      "label": "Tekst",
      "default": "#231F20"
    },
    {
      "type": "color",
      "id": "color_highlight_border",
      "label": "Highlight rand",
      "default": "#160000"
    },
    {
      "type": "color",
      "id": "color_highlight_bg",
      "label": "Highlight achtergrond",
      "default": "#F1F1F1"
    },
    {
      "type": "header",
      "content": "Lettertypes"
    },
    {
      "type": "select",
      "id": "font_heading",
      "label": "Koptekst lettertype",
      "options": [
        { "value": "Bai Jamjuree",      "label": "Bai Jamjuree" },
        { "value": "Playfair Display",  "label": "Playfair Display" },
        { "value": "Inter",             "label": "Inter" }
      ],
      "default": "Bai Jamjuree"
    },
    {
      "type": "select",
      "id": "font_body",
      "label": "Bodytekst lettertype",
      "options": [
        { "value": "Bai Jamjuree",      "label": "Bai Jamjuree" },
        { "value": "Playfair Display",  "label": "Playfair Display" },
        { "value": "Inter",             "label": "Inter" }
      ],
      "default": "Bai Jamjuree"
    }
  ],
  "presets": [
    {
      "name": "LP Hotel Secret"
    }
  ]
}
{% endschema %}
